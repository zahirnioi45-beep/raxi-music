{
  "name": "RAXI MUSIC",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "onCreateCommand": "bash /workspaces/raxi-music/scripts/setup_dev.sh",

  "postStartCommand": "bash /workspaces/raxi-music/scripts/autostart.sh",

  "secrets": [
    "API_ID",
    "API_HASH",
    "BOT_TOKEN",
    "STRING_SESSION",
    "OWNER_ID",
    "OWNER_USERNAME",
    "SUDO_USERS",
    "SPOTIFY_CLIENT_ID",
    "SPOTIFY_CLIENT_SECRET",
    "DONATE_LINK"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.tabSize": 4
      }
    }
  },

  "remoteEnv": {
    "PYTHONPATH": "/workspaces/raxi-music"
  }
}
