{
  "name": "RAXI MUSIC",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "onCreateCommand": "apt-get update -qq && apt-get install -y -qq ffmpeg && python3 -m venv /workspaces/raxi-music/venv && /workspaces/raxi-music/venv/bin/pip install -q --upgrade pip && /workspaces/raxi-music/venv/bin/pip install -q -r /workspaces/raxi-music/requirements.txt && echo '✅ Setup selesai!'",

  "postStartCommand": "bash /workspaces/raxi-music/scripts/autostart.sh",

  "secrets": [
    "API_ID",
    "API_HASH",
    "BOT_TOKEN",
    "STRING_SESSION",
    "OWNER_ID",
    "OWNER_USERNAME",
    "SUDO_USERS",
    "SPOTIFY_CLIENT_ID",
    "SPOTIFY_CLIENT_SECRET",
    "DONATE_LINK"
  ],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.black-formatter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/raxi-music/venv/bin/python3",
        "editor.tabSize": 4
      }
    }
  },

  "remoteEnv": {
    "PYTHONPATH": "/workspaces/raxi-music",
    "VIRTUAL_ENV": "/workspaces/raxi-music/venv",
    "PATH": "/workspaces/raxi-music/venv/bin:${containerEnv:PATH}"
  }
}
