# ╔══════════════════════════════════════╗
# ║        RAXI MUSIC - ENV CONFIG       ║
# ╚══════════════════════════════════════╝

# ── Telegram API ──────────────────────
API_ID=12345678
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here

# ── Pyrogram Session ──────────────────
STRING_SESSION=your_pyrogram_string_session

# ── Owner & Sudo ──────────────────────
OWNER_ID=123456789
OWNER_USERNAME=your_username
SUDO_USERS=123456789,987654321

# ── Bot Info ──────────────────────────
BOT_NAME=RAXI MUSIC
BOT_USERNAME=raximusic_bot

# ── Spotify API (Optional) ────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# ── Donate Links ──────────────────────
DONATE_LINK=https://saweria.co/yourname
QRIS_LINK=https://your-qris-link.com
TRAKTEER_LINK=https://trakteer.id/yourname

# ── Performance ───────────────────────
MAX_QUEUE_SIZE=50
DOWNLOAD_TIMEOUT=60
CACHE_CLEANUP_INTERVAL=3600

# ── Logging ───────────────────────────
LOG_LEVEL=INFO
LOG_CHANNEL=-100xxxxxxxxxx
